#include<bits/stdc++.h>
using namespace std;
#define rep(i,n) for(int i=0;i<n;i++) //rep(i,n); is a shorthand for->for(int i=0; i<n; i++);

struct Node{
    string name;
    int val=0;
    vector<Node*> branch;
    Node* backtracing;
};

//Demostrating fuction
Node* findLab(Node* lab, string lab_name){
    if(lab->branch.empty()) cerr<<"There isn't any lab in the system"<<endl;
    else rep(i,lab->branch.size()+1){
        if(i==lab->branch.size()) cerr<<lab_name<<" doesn't exist"<<endl;
        else if(lab->branch[i]->name==lab_name) return lab->branch[i];
    }
    return nullptr;
}
Node* createNode(string name, int val){
    Node* n=new Node();
    n->name=name;
    n->val=val;
    return n;
}

//Command
void addLab(Node* lab, string lab_name){
    rep(i,lab->branch.size()){
        if(lab->branch[i]->name==lab_name){
            cout<<lab_name<<" has already existed"<<endl;
            return;
        }
    }
    lab->branch.push_back(createNode(lab_name,0));
    cout<<"Lab has successfully added"<<endl;
    return;
}
void removeLab(Node* lab, string lab_name){
    rep(i,lab->branch.size()+1){
        if(i==lab->branch.size()){
            cout<<lab_name<<" doesn't exist"<<endl;
            return;
        }
        if(lab->branch[i]->name==lab_name){
            while(lab->branch[i]->branch.size()){
                Node* temp=lab->branch[i]->branch[0];
                temp->backtracing->val-=temp->val;
                rep(k,temp->backtracing->branch.size()) if(temp->backtracing->branch[k]==temp) temp->backtracing->branch.erase(temp->backtracing->branch.begin()+k);
                lab->branch[i]->branch.erase(lab->branch[i]->branch.begin());
            }
            lab->branch.erase(lab->branch.begin()+i);
            cout<<"Lab has successfully removed"<<endl;
            return;
        }
    }
}
void searchLab(Node* lab){
    if(lab->branch.empty()) cout<<"There isn't any lab in the system"<<endl;
    else rep(i,lab->branch.size()) cout<<i+1<<". "<<lab->branch[i]->name<<endl;
    return;
}
void searchLabClassification(Node* lab, string lab_name){
    if(lab->branch.empty()) cout<<"There isn't any lab in the system"<<endl;
    else rep(i,lab->branch.size()+1){
        if(i==lab->branch.size()) cout<<lab_name<<" is not in the system"<<endl;
        else if(lab->branch[i]->name==lab_name){
            if(!lab->branch[i]->branch.size()) cout<<"empty"<<endl;
            else rep(j,lab->branch[i]->branch.size()) cout<<j+1<<". "<<lab->branch[i]->branch[j]->name<<" "<<lab->branch[i]->branch[j]->val<<endl;
            break;
        }
    }
    return;
}
void searchAllLabClassification(Node* lab){
    if(lab->branch.empty()) cout<<"There isn't any lab in the system"<<endl;
