}
void addSupplyClassification(Node* lab, Node* supply, string supply_name, string lab_name, int initial_amount){
    Node* temp=findLab(lab,lab_name);
    if(temp==nullptr) return;
    rep(i,supply->branch.size()+1){
        if(i==supply->branch.size()){
            supply->branch.push_back(createNode(supply_name,initial_amount));
            Node* create=createNode(lab_name,initial_amount);
            create->branch.push_back(temp);
            create->backtracing=supply->branch[0];
            temp->branch.push_back(create);
            supply->branch[0]->branch.push_back(create);
            break;
        }
        else if(supply->branch[i]->name==supply_name){
            rep(j,supply->branch[i]->branch.size()+1){
                if(j==supply->branch[i]->branch.size()){
                    Node* create=createNode(lab_name,initial_amount);
                    create->branch.push_back(temp);
                    create->backtracing=supply->branch[i];
                    temp->branch.push_back(create);
                    supply->branch[i]->branch.push_back(create);
                    supply->branch[i]->val+=initial_amount;
                    break;
                }
                else if(supply->branch[i]->branch[j]->name==lab_name){
                    cout<<"Supply Classification has already existed"<<endl;
                    supply->branch[i]->branch[j]->val+=initial_amount;
                    supply->branch[i]->val+=initial_amount;
                    break;
                }
            }
        }
    }
    cout<<"Supply Classification has successfully added"<<endl;
    return;
}
void removeSupplyClassification(Node* lab, Node* supply, string supply_name, string lab_name){
    Node* temp=findLab(lab,lab_name);
    if(temp==nullptr) return;
    rep(i,supply->branch.size()+1){
        if(i==supply->branch.size()){
            cout<<"Supply Classification doesn't existed"<<endl;
            return;
        }
        else if(supply->branch[i]->name==supply_name){
            rep(j,supply->branch[i]->branch.size()+1){
                if(j==supply->branch[i]->branch.size()){
                    cout<<"Supply Classification doesn't existed in "<<lab_name<<endl;
                    return;
                }
                else if(supply->branch[i]->branch[j]->name==lab_name){
                    rep(k,temp->branch.size()) if(temp->branch[k]->name==lab_name) temp->branch.erase(temp->branch.begin()+k);
                    supply->branch[i]->val-=supply->branch[i]->branch[j]->val;
                    supply->branch[i]->branch.erase(supply->branch[i]->branch.begin()+j);
                    cout<<"Supply Classification has successfully removed"<<endl;
                    return;
                }
            }
        }
    }
    return;
}
void addSupply(Node* lab, Node* supply, string supply_name, string lab_name, int amount){
    Node* temp=findLab(lab,lab_name);
    if(temp==nullptr) return;
    rep(i,supply->branch.size()+1){
        if(i==supply->branch.size()){
            cout<<"Supply Classification doesn't existed"<<endl;
            supply->branch.push_back(createNode(supply_name,amount));
            Node* create=createNode(lab_name,amount);
            create->branch.push_back(temp);
            create->backtracing=supply->branch[0];
            temp->branch.push_back(create);
            supply->branch[0]->branch.push_back(create);
            break;
        }
        else if(supply->branch[i]->name==supply_name){
            rep(j,supply->branch[i]->branch.size()+1){
                if(j==supply->branch[i]->branch.size()){
                    cout<<"Supply Classification doesn't existed in "<<lab_name<<endl;
                    Node* create=createNode(lab_name,amount);
                    create->branch.push_back(temp);
                    create->backtracing=supply->branch[i];
                    temp->branch.push_back(create);
                    supply->branch[i]->branch.push_back(create);
                    supply->branch[i]->val+=amount;
                    break;
                }
                else if(supply->branch[i]->branch[j]->name==lab_name){
                    supply->branch[i]->branch[j]->val+=amount;
                    supply->branch[i]->val+=amount;
                    break;
                }
            }
        }
    }
    cout<<"Supply has successfully added"<<endl;
    return;
}
void removeSupply(Node* lab, Node* supply, string supply_name, string lab_name, int amount){
    Node* temp=findLab(lab,lab_name);
    if(temp==nullptr) return;
    rep(i,supply->branch.size()+1){
        if(i==supply->branch.size()){
            cout<<"Supply Classification doesn't existed"<<endl;
            return;
        }
        else if(supply->branch[i]->name==supply_name){
            rep(j,supply->branch[i]->branch.size()+1){
                if(j==supply->branch[i]->branch.size()){
                    cout<<"Supply Classification doesn't existed in "<<lab_name<<endl;
                    return;
                }
                else if(supply->branch[i]->branch[j]->name==lab_name){
                    if(supply->branch[i]->branch[j]->val<amount){
                        cout<<"Supply insufficient"<<endl;
                        cout<<"Would you like to remove all the supply?"<<endl<<"True/False"<<endl;
                        bool ans;
                        cin>>ans;
                        cin.ignore();
                        if(ans){
                            supply->branch[i]->val-=supply->branch[i]->branch[j]->val;
                            supply->branch[i]->branch[j]->val=0;
                            cout<<"Supply Classification has successfully removed"<<endl;
                        }
                        else return;
                    }
                    else{
                        supply->branch[i]->val-=amount;
                        supply->branch[i]->branch[j]->val-=amount;
                        cout<<"Supply Classification has successfully removed"<<endl;
                        return;
                    }
                }
            }
        }
    }
    return;
}
