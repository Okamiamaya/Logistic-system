#include<bits/stdc++.h>
using namespace std;
#define rep(i,n) for(int i=0;i<n;i++) //rep(i,n); is a shorthand for->for(int i=0; i<n; i++);
#define mp(s,i) make_pair(s,i)
typedef pair<string,int> pii;
const int mod=1e9+7;

vector<pii> unclassified_data;

class Node{
private:
    string name;
    int val=0;
    vector<Node*> branch;
    Node* backtracing=nullptr;

    string getName(){ return this->name; }
    int getVal(){ return this->val; }

    void addBacktracing(Node* temp){ this->backtracing=temp; }
    void connectNode(Node* temp){ this->branch.push_back(temp); }
    void mutateVal(int val){ this->val+=val; }
    void removeConnection(int index){
        Node* child=this->child(index);
        Node* parent=child->backtracing;
        unclassified_data.push_back(mp(parent->getName(),child->getVal()));
        parent->mutateVal(-child->getVal());
        parent->branch.erase(parent->branch.begin()+parent->findIndex(child->getName()));
        this->branch.erase(this->branch.begin()+index);
    }
    void removeNode(Node* temp){ rep(i,this->branch.size()) if(this->branch[i]==temp){ this->branch.erase(this->branch.begin()+i); return;} }

public:
    Node(string name){ this->name=name; }
    Node(string name, int val){
        this->name=name;
        this->val=val;
    }
    
    Node* child(int index){ return this->branch[index]; }
    int findIndex(string name){
        rep(i,this->branch.size()) if(this->branch[i]->getName()==name) return i;
        return -1;
    }
    void output(){
        if(this->branch.empty()) cout<<"empty"<<endl;
        else{
            rep(i,this->branch.size()){
                Node* rem=this->branch[i];
                cout<<i+1<<". "<<rem->getName();
                if(rem->getVal()) cout<<" "<<rem->getVal();
                cout<<endl;
            }
        }
        return;
    }
    void outputAll(){
        if(this->branch.empty()) cout<<"empty"<<endl;
        else{
            rep(i,this->branch.size()){
                cout<<this->branch[i]->getName()<<endl;
                this->branch[i]->output();
            }
        }
        return;
    }
    void insertNode(string name){ this->branch.push_back(new Node(name)); }
    void removeLab(int index){
        Node* rem=this->branch[index];
        while (rem->branch.size()) rem->removeConnection(0);
        this->branch.erase(this->branch.begin()+index);
        return;
    }
    void mutateClassification(Node* lab, string lab_name, string supply_name, int initial_amount){
        int rem=lab->findIndex(lab_name);
        if(rem==-1) cout<<lab_name<<" not found"<<endl;
        else{
            int index=this->findIndex(supply_name);
            if(index==-1) this->insertNode(supply_name);
            index=this->findIndex(supply_name);
            Node* temp=this->child(index);
            index=temp->findIndex(lab_name);
            if(index==-1){
                Node* create=new Node(lab_name,initial_amount);
                temp->connectNode(create);
                create->connectNode(lab->child(rem));
                lab->child(rem)->connectNode(create);
                create->addBacktracing(temp);
            }
            else temp->child(index)->mutateVal(initial_amount);
            temp->mutateVal(initial_amount);
        }
    }
    void removeClassification(Node* lab, string lab_name, string supply_name){
        int rem=lab->findIndex(lab_name);
        if(rem==-1){ cout<<lab_name<<" not found"<<endl; return; }
        int index=this->findIndex(supply_name);
        if(index==-1){ cout<<"Supply Classification doesn't existed"<<endl; return; }
        Node* parent=this->child(index);
        index=parent->findIndex(lab_name);
        if(index==-1){ cout<<"Supply Classification doesn't existed in "<<lab_name<<endl; return; }
        Node* child=parent->branch[index];
        unclassified_data.push_back(mp(parent->getName(),child->getVal()));
        index=lab->findIndex(lab_name);
        Node* temp=lab->child(index);
        temp->removeNode(child);
        parent->branch.erase(parent->branch.begin()+parent->findIndex(lab_name));
        parent->mutateVal(-child->getVal());
        cout<<"Supply Classification has successfully removed"<<endl;
    }

};


Node* lab=new Node("head");
Node* supply=new Node("head");


int command(string c){
    int ans=0;
    rep(i,c.size()) ans=(ans*42+((int)toupper(c[i])-48))%mod;
    return ans;
}
int cal(string supply_name){
    int ans=0;
    for(int i=unclassified_data.size()-1;i>=0;i--) if(unclassified_data[i].first==supply_name){ ans+=unclassified_data[i].second; unclassified_data.erase(unclassified_data.begin()+i); }
    return ans;
}
